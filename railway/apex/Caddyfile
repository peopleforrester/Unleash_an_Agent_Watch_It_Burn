# ABOUTME: Apex landing page + wildcard Host-based router for agenticburn.com on Railway.
# ABOUTME: Railway terminates TLS at its edge; this serves plain HTTP on $PORT and proxies by Host.
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	# Apex + www -> the static landing page.
	@site host agenticburn.com www.agenticburn.com
	handle @site {
		root * /srv/site
		file_server
	}

	# provisioning.agenticburn.com -> the credential distributor (its own Railway service). Railway won't
	# let that service also claim the subdomain (it overlaps this service's *.agenticburn.com wildcard),
	# so the wildcard cert is terminated here and the request is proxied to the distributor over TLS.
	@provisioning host provisioning.agenticburn.com
	handle @provisioning {
		reverse_proxy watch-it-burn-provisioning-production.up.railway.app:443 {
			transport http {
				tls
				tls_server_name watch-it-burn-provisioning-production.up.railway.app
			}
			header_up Host watch-it-burn-provisioning-production.up.railway.app
		}
	}

	# rounds.agenticburn.com -> the Rounds & Challenges review deck (its own Railway service). Same
	# wildcard-overlap reason as provisioning: terminate the wildcard cert here, proxy to the deck over TLS.
	@rounds host rounds.agenticburn.com
	handle @rounds {
		reverse_proxy watch-it-burn-rounds-production.up.railway.app:443 {
			transport http {
				tls
				tls_server_name watch-it-burn-rounds-production.up.railway.app
			}
			header_up Host watch-it-burn-rounds-production.up.railway.app
		}
	}

	# Everything else (a-<id>, burn, wall, tiers) -> the cluster LB from the routes map.
	# routes.map is generated by the provisioner: one "host  http://<cluster-lb-host>" per line.
	handle {
		map {host} {upstream} {
			import /etc/caddy/routes.map
			default ""
		}
		@routed `{upstream} != ""`
		handle @routed {
			reverse_proxy {upstream}
		}
		# Unknown host -> friendly page (e.g. a cluster not yet provisioned / spare rotated out).
		handle {
			root * /srv/site
			rewrite * /unknown.html
			file_server {
				status 404
			}
		}
	}
}
