# ABOUTME: Apex landing page + wildcard Host-based router for agenticburn.com on Railway.
# ABOUTME: Railway terminates TLS at its edge; this serves plain HTTP on $PORT and proxies by Host.
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	# Apex + www -> the static landing page.
	@site host agenticburn.com www.agenticburn.com
	handle @site {
		root * /srv/site
		file_server
	}

	# Everything else (a-<id>, burn, wall, tiers) -> the cluster LB from the routes map.
	# routes.map is generated by the provisioner: one "host  http://<cluster-lb-host>" per line.
	handle {
		map {host} {upstream} {
			import /etc/caddy/routes.map
			default ""
		}
		@routed `{upstream} != ""`
		handle @routed {
			reverse_proxy {upstream}
		}
		# Unknown host -> friendly page (e.g. a cluster not yet provisioned / spare rotated out).
		handle {
			root * /srv/site
			rewrite * /unknown.html
			file_server {
				status 404
			}
		}
	}
}
