# Terraform working files: never commit state, plans, provider plugins, or lockfile churn.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# Per-account state dirs + provisioning run logs (generated by fleet.sh/terraform, never source).
# Path-neutral so the aws/ (and future azure/gcp/) relocation keeps ignoring them.
**/states/
*.log
*.apply.log
*.reapply.log
